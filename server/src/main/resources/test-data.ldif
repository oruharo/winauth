# LDAP Test Data for Windows Authentication Simulation
# Base Domain
dn: dc=testdomain,dc=local
objectclass: top
objectclass: domain
objectclass: extensibleObject
dc: testdomain

# Admin User
dn: cn=admin,dc=testdomain,dc=local
objectclass: simpleSecurityObject
objectclass: organizationalRole
cn: admin
description: LDAP administrator
userPassword: admin123

# Organizational Unit for Users
dn: ou=users,dc=testdomain,dc=local
objectclass: organizationalUnit
ou: users
description: All users

# Organizational Unit for Groups
dn: ou=groups,dc=testdomain,dc=local
objectclass: organizationalUnit
ou: groups
description: All groups

# Test User 1
dn: uid=testuser,ou=users,dc=testdomain,dc=local
objectclass: inetOrgPerson
objectclass: person
objectclass: top
cn: Test User
sn: User
uid: testuser
userPassword: password123
mail: testuser@testdomain.local
telephoneNumber: 123-456-7890
description: Test user for Windows authentication simulation

# Admin User
dn: uid=admin,ou=users,dc=testdomain,dc=local
objectclass: inetOrgPerson
objectclass: person
objectclass: top
cn: Administrator
sn: Admin
uid: admin
userPassword: admin123
mail: admin@testdomain.local
description: Administrator user

# Domain Users Group
dn: cn=Domain Users,ou=groups,dc=testdomain,dc=local
objectclass: groupOfNames
objectclass: top
cn: Domain Users
description: All domain users
member: uid=testuser,ou=users,dc=testdomain,dc=local
member: uid=admin,ou=users,dc=testdomain,dc=local

# Domain Admins Group
dn: cn=Domain Admins,ou=groups,dc=testdomain,dc=local
objectclass: groupOfNames
objectclass: top
cn: Domain Admins
description: Domain administrators
member: uid=admin,ou=users,dc=testdomain,dc=local

# Remote Desktop Users Group
dn: cn=Remote Desktop Users,ou=groups,dc=testdomain,dc=local
objectclass: groupOfNames
objectclass: top
cn: Remote Desktop Users
description: Users allowed to log on remotely
member: uid=testuser,ou=users,dc=testdomain,dc=local